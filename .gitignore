# Copilot Adapter Logs Viewer - .gitignore

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# OMC state (dev tooling)
.omc/

# Sample log files (contain potentially sensitive data)
*.json
!package.json

# Node modules (if any dev tools added later)
node_modules/
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
